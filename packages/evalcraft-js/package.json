{
  "name": "evalcraft",
  "version": "0.1.0",
  "description": "The pytest for AI agents — TypeScript/JavaScript SDK",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./adapters/vercel-ai": {
      "import": "./dist/adapters/vercel-ai.mjs",
      "require": "./dist/adapters/vercel-ai.js",
      "types": "./dist/adapters/vercel-ai.d.ts"
    },
    "./adapters/gemini": {
      "import": "./dist/adapters/gemini.mjs",
      "require": "./dist/adapters/gemini.js",
      "types": "./dist/adapters/gemini.d.ts"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "ai",
    "agent",
    "testing",
    "eval",
    "llm",
    "cassette"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.0.0",
    "ai": "^6.0.116",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0",
    "vitest": "^1.2.0"
  },
  "peerDependencies": {
    "ai": ">=3.0.0",
    "openai": ">=4.0.0",
    "@anthropic-ai/sdk": ">=0.30.0",
    "@google/generative-ai": ">=0.12.0"
  },
  "peerDependenciesMeta": {
    "ai": {
      "optional": true
    },
    "openai": {
      "optional": true
    },
    "@anthropic-ai/sdk": {
      "optional": true
    },
    "@google/generative-ai": {
      "optional": true
    }
  }
}
